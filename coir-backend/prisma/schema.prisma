generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  INDIVIDUAL
  BUSINESS
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id Int @id @default(autoincrement())

  mobile   String  @unique
  email    String? @unique
  password String?

  otpHash          String?
  otpExpiresAt     DateTime?
  refreshTokenHash String?

  userType UserType

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile?

  applications Application[]
}

model Profile {
  id Int @id @default(autoincrement())

  userId Int @unique

  fullName String

  dob DateTime?

  gender String?

  photo String?

  address    String?
  city       String?
  district   String?
  state      String?
  country    String?
  postalCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Scheme {
  id Int @id @default(autoincrement())

  code String @unique

  name String

  description String?

  duration String?

  stipend Decimal? @db.Decimal(10,2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]
  courses Course[]
}


model TrainingCentre {
  id Int @id @default(autoincrement())

  name String

  district String?

  state String?

  address String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]
}

model Course {
  id Int @id @default(autoincrement())

  schemeId Int

  title String

  category String?

  duration String?

  benefit String?

  level String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheme Scheme @relation(fields: [schemeId], references: [id])

  applications Application[]
}

model Application {
  id Int @id @default(autoincrement())

  applicationNo String @unique

  userId Int

  schemeId Int

  courseId Int

  trainingCentreId Int?

  status ApplicationStatus @default(DRAFT)

  currentStep Int @default(1)
  
  submittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  scheme Scheme @relation(fields: [schemeId], references: [id])

  course Course @relation(fields: [courseId], references: [id])

  trainingCentre TrainingCentre? @relation(fields: [trainingCentreId], references: [id])

  detail ApplicationDetail?

  logs ApplicationLog[]
}

model ApplicationDetail {
  id Int @id @default(autoincrement())

  applicationId Int @unique

  personalDetails Json?

  experienceDetails Json?

  bankDetails Json?

  documents Json?

  declarationAcceptedAt DateTime?

  declarationAccepted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

//future approval tracking ke liye

model ApplicationLog {
  id Int @id @default(autoincrement())

  applicationId Int

  action String

  remarks String?

  createdAt DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
}
